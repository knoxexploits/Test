local _T={}
local _N={}
local function wowDecode(t)
local c=_T[t]
if not c then return t end
local r=""
for i=1,#c do r=r..string.char(c[i])end
return r
end
local function niceNumber(t)
local v=_N[t]
if v==nil then return 0 end
return v
end
local function load(tk,nk,chunks)
_T=tk
_N=nk or{}
rawset(_G,"wowDecode",wowDecode)
rawset(_G,"niceNumber",niceNumber)
for i=1,#chunks do
local ok,e=pcall(function()
local fn,err=loadstring(chunks[i])
if not fn then warn("[E]"..tostring(err))return end
fn()
end)
if not ok then warn("[E]"..tostring(e))end
end
end
return load
