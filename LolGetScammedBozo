-- BRAIN | Illunox
-- This is the runtime that decodes and runs your scripts

local function load(tk, nk, chunks)
    for i = 1, #chunks do
        local ok, e = pcall(function()
            -- Build the decoder functions fresh for each chunk
            -- using the token tables passed from loader
            local env_T = tk
            local env_N = nk or {}

            -- Inject decoders into the chunk's environment via upvalues
            -- The chunk already has them inlined so just run it
            local fn, err = loadstring(chunks[i])
            if not fn then
                warn("[Brain] " .. tostring(err))
                return
            end
            fn()
        end)
        if not ok then
            warn("[Brain] " .. tostring(e))
        end
    end
end

return load
